{
  "name": "@leinad4mind/core",
  "version": "0.1.0",
  "description": "FFmpeg WebAssembly version (single thread, wasm-memory64 / 8 GiB max heap)",
  "main": "./dist/umd/ffmpeg-core.js",
  "exports": {
    ".": {
      "import": "./dist/esm/ffmpeg-core.js",
      "require": "./dist/umd/ffmpeg-core.js"
    },
    "./wasm": {
      "import": "./dist/esm/ffmpeg-core.wasm",
      "require": "./dist/umd/ffmpeg-core.wasm"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yari-dev/ffmpeg-wasm-browser.git"
  },
  "keywords": [
    "ffmpeg",
    "WebAssembly",
    "video",
    "audio",
    "transcode"
  ],
  "author": "Jerome Wu <jeromewus@gmail.com>",
  "license": "GPL-2.0-or-later",
  "bugs": {
    "url": "https://github.com/yari-dev/ffmpeg-wasm-browser/issues"
  },
  "engines": {
    "node": ">=16.x"
  },
  "homepage": "https://github.com/yari-dev/ffmpeg-wasm-browser#readme",
  "publishConfig": {
    "access": "public"
  }
}
